{
  "name": "@prehoy/baguette",
  "version": "0.5.2",
  "description": "Blazingly fast, zero-config Bun + Hono API framework. Drop a file, get a typed, documented, validated endpoint.",
  "license": "MIT",
  "homepage": "https://usebaguette.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prehoy/baguette.git"
  },
  "bugs": "https://github.com/prehoy/baguette/issues",
  "keywords": [
    "bun",
    "hono",
    "api",
    "framework",
    "zod",
    "openapi",
    "typescript",
    "file-based-routing"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "baguette": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./cron": { "types": "./dist/cron.d.ts", "default": "./dist/cron.js" },
    "./automations": { "types": "./dist/automations.d.ts", "default": "./dist/automations.js" },
    "./queue": { "types": "./dist/queue.d.ts", "default": "./dist/queue.js" },
    "./email": { "types": "./dist/email.d.ts", "default": "./dist/email.js" },
    "./eslint": { "types": "./dist/eslint.d.ts", "default": "./dist/eslint.js" }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun --hot examples/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && { printf '#!/usr/bin/env bun\\n'; grep -v '^#!/usr/bin/env bun' dist/cli.js; } > dist/cli.tmp && mv dist/cli.tmp dist/cli.js && chmod +x dist/cli.js",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.11.3",
    "cron": "^4.4.0",
    "hono": "^4.12.25",
    "postgres": "^3.4.9",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@react-email/components": "^0.0.32",
    "@react-email/render": "^1.0.0",
    "@types/bun": "latest",
    "@types/nodemailer": "^6.4.0",
    "@types/react": "^19.0.0",
    "bee-queue": "^1.7.1",
    "nodemailer": "^6.9.0",
    "react": "^19.0.0",
    "resend": "^4.0.0"
  },
  "peerDependencies": {
    "@react-email/render": ">=1",
    "bee-queue": ">=1.6",
    "nodemailer": ">=6",
    "react": ">=18",
    "typescript": "^5.6.0"
  },
  "peerDependenciesMeta": {
    "@react-email/render": { "optional": true },
    "bee-queue": { "optional": true },
    "nodemailer": { "optional": true },
    "react": { "optional": true }
  }
}
