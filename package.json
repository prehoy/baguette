{
  "name": "baguette",
  "version": "0.0.1",
  "description": "Blazingly fast, zero-config Bun + Hono API framework. Drop a file, get a typed, documented, validated endpoint.",
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "baguette": "src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./cron": "./src/cron.ts",
    "./automations": "./src/automations.ts",
    "./eslint": "./src/eslint.ts"
  },
  "scripts": {
    "dev": "bun --hot examples/server.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.11.3",
    "cron": "^4.4.0",
    "hono": "^4.12.25",
    "postgres": "^3.4.9",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.6.0"
  }
}
